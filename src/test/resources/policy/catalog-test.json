{
  "version": "test.v1",
  "defaults": {
    "coverage": {
      "required": ["OTHER_SUPPORTING"],
      "recommended": []
    },
    "rules": {
      "allowedFormats": ["PDF"],
      "totalSizeLimitBytes": 1000
    }
  },
  "platform": {
    "STRIPE": {
      "coverage": {
        "required": ["ORDER_RECEIPT"]
      },
      "rules": {
        "singleFilePerEvidenceType": true,
        "totalSizeLimitBytes": 2000
      }
    }
  },
  "scope": {
    "STRIPE_DISPUTE": {
      "coverage": {
        "required": ["CUSTOMER_DETAILS"]
      },
      "rules": {
        "externalLinksAllowed": false,
        "totalSizeLimitBytes": 3000
      }
    }
  },
  "reason": {
    "RC_1": {
      "coverage": {
        "required": ["POLICIES"]
      },
      "rules": {
        "totalPagesLimit": 49,
        "totalSizeLimitBytes": 4000
      }
    }
  },
  "network": {
    "VISA": {
      "coverage": {
        "required": ["FULFILLMENT_DELIVERY"]
      },
      "rules": {
        "perPdfPageLimit": 10,
        "totalSizeLimitBytes": 5000
      }
    }
  }
